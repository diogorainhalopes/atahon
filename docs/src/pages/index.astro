---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import ScreenshotCarousel from '../components/ScreenshotCarousel.tsx';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout>
  <!-- Hero -->
  <Hero />

  <!-- Features -->
  <FeatureGrid />

  <!-- Screenshots -->
  <section id="screenshots" class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center" data-animate>
        <h2 class="text-3xl font-bold text-text-primary sm:text-4xl">
          See it in action
        </h2>
        <p class="mt-4 text-lg text-text-secondary">
          A clean, focused reading experience designed for manga.
        </p>
      </div>
      <div data-animate>
        <ScreenshotCarousel base={base} client:visible />
      </div>
    </div>
  </section>

  <!-- Technical Highlights -->
  <section class="px-6 py-24">
    <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-2">
      <!-- Offline-first -->
      <div
        data-animate
        class="rounded-2xl border border-border bg-background-card p-8"
      >
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-status-info/10 text-status-info">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
          </svg>
        </div>
        <h3 class="mb-2 text-xl font-bold text-text-primary">Offline-First Architecture</h3>
        <p class="text-text-secondary">
          Your entire library lives in a local database powered.
          Downloaded chapters are stored on-device. No account required, no cloud dependency.
          Your data is yours.
        </p>
      </div>

      <!-- Extension compatibility -->
      <div
        data-animate
        class="rounded-2xl border border-border bg-background-card p-8"
        style="transition-delay: 100ms;"
      >
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-status-success/10 text-status-success">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 01-.657.643 48.39 48.39 0 01-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 01-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 00-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 01-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 00.657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 01-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 005.427-.63 48.05 48.05 0 00.582-4.717.532.532 0 00-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.959.401v0a.656.656 0 00.658-.663 48.422 48.422 0 00-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 01-.61-.58v0z" />
          </svg>
        </div>
        <h3 class="mb-2 text-xl font-bold text-text-primary">Tachiyomi Extension Support</h3>
        <p class="text-text-secondary">
          Full compatibility with Tachiyomi and Mihon extension APKs. A native Kotlin bridge loads
          extensions directly, giving you access to the entire ecosystem of community-maintained sources.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden px-6 py-24">
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(ellipse at center bottom, rgba(124, 110, 248, 0.08) 0%, transparent 60%);"
    >
    </div>
    <div class="relative mx-auto max-w-2xl text-center" data-animate>
      <h2 class="text-3xl font-bold text-text-primary sm:text-4xl">
        Ready to start reading?
      </h2>
      <p class="mt-4 text-lg text-text-secondary">
        Download Atahon and set up your library in minutes.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="https://github.com/diogorainhalopes/atahon/releases"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl bg-accent px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-accent/25 transition-all hover:bg-accent-hover hover:-translate-y-0.5"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Download APK
        </a>
        <a
          href={`${base}/docs/`}
          class="inline-flex items-center gap-2 rounded-xl border border-border px-8 py-3.5 text-base font-semibold text-text-primary transition-all hover:border-accent/40 hover:bg-accent-muted"
        >
          View Documentation
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

---
const navLinks = [
  { label: 'Features', href: '/#features' },
  { label: 'Screenshots', href: '/#screenshots' },
  { label: 'Docs', href: '/docs/' },
];

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header
  class="fixed top-0 left-0 right-0 z-50 border-b border-border-subtle/50 bg-background/80 backdrop-blur-xl"
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href={`${base}/`} class="flex items-center gap-3 transition-opacity hover:opacity-80">
      <img src={`${base}/icon.png`} alt="Atahon" class="h-8 w-8 rounded-lg" />
      <span class="text-lg font-bold text-text-primary">Atahon</span>
    </a>

    <!-- Desktop links -->
    <div class="hidden items-center gap-8 md:flex">
      {
        navLinks.map((link) => (
          <a
            href={`${base}${link.href}`}
            class="text-sm font-medium text-text-secondary transition-colors hover:text-text-primary"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={`${base}/docs/`}
        class="rounded-lg bg-accent px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-accent-hover"
      >
        Get Started
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="flex h-10 w-10 items-center justify-center rounded-lg text-text-secondary transition-colors hover:bg-surface hover:text-text-primary md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="menu-icon-open" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-icon-close" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu overlay -->
  <div
    id="mobile-menu"
    class="hidden border-t border-border-subtle bg-background/95 backdrop-blur-xl md:hidden"
  >
    <div class="flex flex-col gap-1 px-6 py-4">
      {
        navLinks.map((link) => (
          <a
            href={`${base}${link.href}`}
            class="mobile-menu-link rounded-lg px-4 py-3 text-sm font-medium text-text-secondary transition-colors hover:bg-surface hover:text-text-primary"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={`${base}/docs/`}
        class="mobile-menu-link mt-2 rounded-lg bg-accent px-4 py-3 text-center text-sm font-semibold text-white transition-colors hover:bg-accent-hover"
      >
        Get Started
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('menu-icon-open')!;
  const iconClose = document.getElementById('menu-icon-close')!;

  btn.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('hidden');
    // isOpen is true when 'hidden' was just added (menu closed)
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu on link click
  menu.querySelectorAll('.mobile-menu-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    });
  });
</script>
